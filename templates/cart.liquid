<div class="page-wrap">
    <div class="page-container">
        <h1 class="page-title">YOUR CART</h1>

        {%- if cart.item_count > 0 -%}
            <form action="{{ routes.cart_url }}" method="post" novalidate>
                <div class="cart-grid">
                    <div class="cart-items">
                        {%- for item in cart.items -%}
                        <div class="cart-item" data-key="{{ item.key }}">
                            <div class="cart-item-img">
                                {%- if item.image -%}
                                    <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}">
                                {%- else -%}
                                    <img src="https://placehold.co/200x200/1B2838/F0E6D3?text=Fabric" alt="{{ item.title | escape }}">
                                {%- endif -%}
                            </div>
                            <div>
                                <div class="cart-item-name">
                                    <a href="{{ item.url }}">{{ item.product.title }}</a>
                                </div>
                                {%- unless item.product.has_only_default_variant -%}
                                    <div class="cart-item-meta">{{ item.variant.title }}</div>
                                {%- endunless -%}
                                <div class="cart-item-meta">{{ item.price | money }} × {{ item.quantity }}</div>
                                <div class="cart-item-price">{{ item.line_price | money }}</div>
                            </div>
                            <div class="cart-item-actions">
                                <div class="qty-selector" style="border:1px solid var(--card-border);">
                                    <a class="qty-btn" href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity={{ item.quantity | minus: 1 }}">&minus;</a>
                                    <input type="number" name="updates[]" class="qty-input" value="{{ item.quantity }}" min="1" data-key="{{ item.key }}">
                                    <a class="qty-btn" href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity={{ item.quantity | plus: 1 }}">+</a>
                                </div>
                                <a class="cart-item-remove" href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity=0">Remove</a>
                            </div>
                        </div>
                        {%- endfor -%}
                    </div>

                    <div class="cart-summary">
                        <h3>Order Summary</h3>
                        <div class="summary-row"><span>Subtotal</span><span>{{ cart.total_price | money }}</span></div>
                        <div class="summary-row"><span>Shipping</span><span>{%- if cart.total_price >= 300000 -%}FREE{%- else -%}Calculated at checkout{%- endif -%}</span></div>
                        <div class="summary-row total"><span>Total</span><span>{{ cart.total_price | money }}</span></div>

                        <label class="spec-label" style="display:block; margin: 20px 0 8px;">Order Notes</label>
                        <textarea name="note" class="form-input" style="min-height: 80px; resize: vertical;" placeholder="Special instructions (optional)">{{ cart.note }}</textarea>

                        <div style="display:flex; gap:10px; margin-top: 16px;">
                            <button type="submit" name="update" class="btn-cart" style="flex:1;">UPDATE</button>
                            <button type="submit" name="checkout" class="btn-checkout" style="flex:2;">CHECKOUT</button>
                        </div>
                    </div>
                </div>
            </form>
        {%- else -%}
            <div class="cart-empty">
                <h2>Your cart is empty</h2>
                <p>Looks like you haven't added any fabrics yet.</p>
                <a href="{{ routes.root_url }}" class="btn-continue">CONTINUE SHOPPING</a>
            </div>
        {%- endif -%}
    </div>
</div>
