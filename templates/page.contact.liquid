<div class="contact-wrap" style="padding: 140px 24px 80px; position: relative; z-index: 1; min-height: calc(100vh - 40px);">
    <div class="contact-container" style="max-width: 1000px; margin: 0 auto;">
        <div class="contact-heading" style="text-align: center; margin-bottom: 48px;">
            <h1 class="contact-title" style="font-family: 'Space Grotesk', sans-serif; font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 700; letter-spacing: 4px; color: var(--text); margin-bottom: 12px;">{{ page.title | default: 'GET IN TOUCH' | upcase }}</h1>
            <p class="contact-subtitle" style="color: var(--subtitle); font-size: clamp(0.95rem, 2vw, 1.15rem); font-style: italic; letter-spacing: 3px;">&ldquo;We'd love to hear from you&rdquo;</p>
        </div>

        <div class="contact-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 48px; margin-top: 48px;">
            <!-- Info Card -->
            <div class="contact-info-card" style="background: rgba(27, 40, 56, 0.6); border: 1px solid var(--card-border); border-radius: 12px; padding: 32px; backdrop-filter: blur(10px);">
                <h3 class="contact-info-title" style="font-family: 'Space Grotesk', sans-serif; font-size: 1.1rem; color: var(--gold); letter-spacing: 2px; margin-bottom: 20px; text-transform: uppercase;">Reach Us</h3>

                <div class="contact-info-item" style="display: flex; align-items: flex-start; gap: 16px; padding: 16px 0; border-bottom: 1px solid var(--card-border);">
                    <div class="contact-info-icon" style="flex-shrink: 0; width: 40px; height: 40px; background: rgba(201, 168, 76, 0.1); border: 1px solid rgba(201, 168, 76, 0.3); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: var(--gold);">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    </div>
                    <div class="contact-info-content">
                        <h4 style="font-size: 0.8rem; color: var(--subtitle); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 4px;">Address</h4>
                        <p style="font-size: 0.95rem; color: var(--text);">Lahore, Pakistan</p>
                    </div>
                </div>

                <div class="contact-info-item" style="display: flex; align-items: flex-start; gap: 16px; padding: 16px 0; border-bottom: 1px solid var(--card-border);">
                    <div class="contact-info-icon" style="flex-shrink: 0; width: 40px; height: 40px; background: rgba(201, 168, 76, 0.1); border: 1px solid rgba(201, 168, 76, 0.3); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: var(--gold);">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
                    </div>
                    <div class="contact-info-content">
                        <h4 style="font-size: 0.8rem; color: var(--subtitle); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 4px;">Phone</h4>
                        <a href="tel:+923113638999" style="font-size: 0.95rem; color: var(--text);">+92 311 3638999</a>
                    </div>
                </div>

                <div class="contact-info-item" style="display: flex; align-items: flex-start; gap: 16px; padding: 16px 0; border-bottom: 1px solid var(--card-border);">
                    <div class="contact-info-icon" style="flex-shrink: 0; width: 40px; height: 40px; background: rgba(201, 168, 76, 0.1); border: 1px solid rgba(201, 168, 76, 0.3); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: var(--gold);">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    </div>
                    <div class="contact-info-content">
                        <h4 style="font-size: 0.8rem; color: var(--subtitle); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 4px;">Email</h4>
                        <a href="mailto:hello@zarshah.pk" style="font-size: 0.95rem; color: var(--text);">hello@zarshah.pk</a>
                    </div>
                </div>

                <div class="contact-info-item" style="display: flex; align-items: flex-start; gap: 16px; padding: 16px 0;">
                    <div class="contact-info-icon" style="flex-shrink: 0; width: 40px; height: 40px; background: rgba(201, 168, 76, 0.1); border: 1px solid rgba(201, 168, 76, 0.3); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: var(--gold);">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    </div>
                    <div class="contact-info-content">
                        <h4 style="font-size: 0.8rem; color: var(--subtitle); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 4px;">Hours</h4>
                        <p style="font-size: 0.95rem; color: var(--text);">Mon – Sat: 10am – 9pm<br>Sunday: Closed</p>
                    </div>
                </div>
            </div>

            <!-- Form Card -->
            <div class="contact-form-card" style="background: rgba(27, 40, 56, 0.6); border: 1px solid var(--card-border); border-radius: 12px; padding: 32px; backdrop-filter: blur(10px);">
                <h3 class="contact-info-title" style="font-family: 'Space Grotesk', sans-serif; font-size: 1.1rem; color: var(--gold); letter-spacing: 2px; margin-bottom: 20px; text-transform: uppercase;">Send a Message</h3>

                {% form 'contact' %}
                    {%- if form.posted_successfully? -%}
                        <p style="color: #4ade80; padding: 12px; background: rgba(74, 222, 128, 0.1); border-radius: 6px; margin-bottom: 16px;">Thanks! We'll get back to you soon.</p>
                    {%- endif -%}
                    {%- if form.errors -%}
                        <p style="color: #f87171; padding: 12px; background: rgba(248, 113, 113, 0.1); border-radius: 6px; margin-bottom: 16px;">{{ form.errors | default_errors }}</p>
                    {%- endif -%}

                    <div class="form-group" style="margin-bottom: 20px;">
                        <label class="form-label" style="display: block; font-size: 0.75rem; color: var(--subtitle); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 8px;">Name</label>
                        <input type="text" name="contact[name]" class="form-input" placeholder="Your full name" required>
                    </div>

                    <div class="form-group" style="margin-bottom: 20px;">
                        <label class="form-label" style="display: block; font-size: 0.75rem; color: var(--subtitle); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 8px;">Email</label>
                        <input type="email" name="contact[email]" class="form-input" placeholder="your@email.com" required>
                    </div>

                    <div class="form-group" style="margin-bottom: 20px;">
                        <label class="form-label" style="display: block; font-size: 0.75rem; color: var(--subtitle); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 8px;">Phone (Optional)</label>
                        <input type="tel" name="contact[phone]" class="form-input" placeholder="+92 300 0000000">
                    </div>

                    <div class="form-group" style="margin-bottom: 20px;">
                        <label class="form-label" style="display: block; font-size: 0.75rem; color: var(--subtitle); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 8px;">Message</label>
                        <textarea name="contact[body]" class="form-textarea" placeholder="How can we help you?" required></textarea>
                    </div>

                    <button type="submit" class="btn-submit">SEND MESSAGE &rarr;</button>
                {% endform %}
            </div>
        </div>
    </div>
</div>

<style>
@media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
}
</style>
