{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign on_sale = false -%}
{%- if current_variant.compare_at_price > current_variant.price -%}
    {%- assign on_sale = true -%}
    {%- assign discount = current_variant.compare_at_price | minus: current_variant.price | times: 100.0 | divided_by: current_variant.compare_at_price | round -%}
{%- endif -%}

<nav class="breadcrumb">
    <a href="{{ routes.root_url }}">Home</a>
    <span class="sep">/</span>
    <a href="/collections/all">Collection</a>
    <span class="sep">/</span>
    <span class="current">{{ product.title }}</span>
</nav>

<div class="product-wrap">
    <div class="product-container">
        <!-- Images -->
        <div class="product-images">
            <div class="product-gallery" id="productGallery">
                {%- if product.images.size > 0 -%}
                    {%- for image in product.images -%}
                        <div class="product-slide" data-index="{{ forloop.index0 }}">
                            <img src="{{ image | image_url: width: 1000 }}" alt="{{ image.alt | default: product.title | escape }}" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
                        </div>
                    {%- endfor -%}
                {%- else -%}
                    <div class="product-slide" data-index="0">
                        <img src="https://placehold.co/800x880/1B2838/F0E6D3?text={{ product.title | url_encode }}" alt="{{ product.title | escape }}">
                    </div>
                {%- endif -%}

                {%- if product.images.size > 1 -%}
                    <button type="button" class="gallery-arrow gallery-arrow--prev" id="galleryPrev" aria-label="Previous image">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                    </button>
                    <button type="button" class="gallery-arrow gallery-arrow--next" id="galleryNext" aria-label="Next image">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                    </button>
                    <div class="gallery-counter" id="galleryCounter" aria-live="polite">1 / {{ product.images.size }}</div>
                {%- endif -%}
            </div>

            {%- if product.images.size > 1 -%}
            <div class="gallery-dots" id="galleryDots" role="tablist" aria-label="Product images">
                {%- for image in product.images -%}
                    <button type="button" class="gallery-dot {% if forloop.first %}is-active{% endif %}" data-slide="{{ forloop.index0 }}" role="tab" aria-label="Go to image {{ forloop.index }}"></button>
                {%- endfor -%}
            </div>

            <div class="product-thumbs" role="list">
                {%- for image in product.images -%}
                <button type="button" class="product-thumb {% if forloop.first %}active{% endif %}" data-slide="{{ forloop.index0 }}" aria-label="View image {{ forloop.index }}">
                    <img src="{{ image | image_url: width: 200 }}" alt="{{ image.alt | default: product.title | escape }}" loading="lazy">
                </button>
                {%- endfor -%}
            </div>
            {%- endif -%}
        </div>

        <!-- Details -->
        <div class="product-details">
            <h1 class="product-title">{{ product.title }}</h1>
            {%- if product.type != blank -%}
                <p class="product-subtitle">{{ product.type }}</p>
            {%- endif -%}

            {% comment %} Judge.me star-rating preview — shows under title, links to reviews section {% endcomment %}
            <div class="jdgm-widget jdgm-preview-badge product-rating-preview"
                 data-id="{{ product.id }}"
                 data-template="product">
                {{ product.metafields.judgeme.badge }}
            </div>

            <!-- Fabric badge — every Zarshah piece is Wash & Wear -->
            <div class="fabric-badge" aria-label="Fabric type">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M3 7l3-4h12l3 4-3 4H6L3 7z"/>
                    <path d="M3 7v10a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V7"/>
                </svg>
                <span><strong>Fabric:</strong> Wash &amp; Wear</span>
            </div>

            <div class="product-price-block">
                <span class="product-price-new" id="productPrice">{{ current_variant.price | money }}</span>
                {%- if on_sale -%}
                    <span class="product-price-old" id="productComparePrice">{{ current_variant.compare_at_price | money }}</span>
                    <span class="product-discount">-{{ discount }}%</span>
                {%- endif -%}
            </div>

            {%- assign urgency_threshold = 20 -%}
            {%- assign show_urgency = false -%}
            {%- if current_variant.inventory_management != blank and current_variant.inventory_quantity > 0 and current_variant.inventory_quantity <= urgency_threshold -%}
                {%- assign show_urgency = true -%}
            {%- endif -%}
            <div class="stock-urgency{% unless show_urgency %} is-hidden{% endunless %}" id="stockUrgency" data-threshold="{{ urgency_threshold }}">
                <p class="stock-urgency-text">
                    Hurry! Only <span class="stock-urgency-count" id="stockUrgencyCount">{{ current_variant.inventory_quantity | default: 0 }}</span> left in stock.
                </p>
                <div class="stock-urgency-bar">
                    {%- assign fill_pct = current_variant.inventory_quantity | times: 100 | divided_by: urgency_threshold -%}
                    {%- if fill_pct > 100 -%}{%- assign fill_pct = 100 -%}{%- endif -%}
                    <div class="stock-urgency-fill" id="stockUrgencyFill" style="width: {{ fill_pct }}%;"></div>
                </div>
            </div>

            <p class="product-tax-note">Tax included. Shipping calculated at checkout.</p>

            <form action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data" id="productForm">
                <input type="hidden" name="id" id="variantId" value="{{ current_variant.id }}">
                <input type="hidden" name="quantity" id="qtyInputHidden" value="1">

                {%- comment -%} Action buttons surface right under the price for fast checkout {%- endcomment -%}
                <div class="product-actions">
                    <button type="submit" name="add" class="btn-cart" {% unless current_variant.available %}disabled{% endunless %}>
                        {%- if current_variant.available -%}ADD TO CART{%- else -%}SOLD OUT{%- endif -%}
                    </button>
                    <button type="button" class="btn-buy" onclick="handleBuyNow()" {% unless current_variant.available %}disabled{% endunless %}>BUY NOW</button>
                </div>

                {%- if product.description != blank -%}
                    <div class="product-description">{{ product.description }}</div>
                {%- endif -%}

                {%- if product.has_only_default_variant == false -%}
                    <div class="product-specs">
                        <h3>Options</h3>
                        {%- for option in product.options_with_values -%}
                            <div style="margin-bottom: 16px;">
                                <label class="spec-label" style="display:block; margin-bottom: 8px;">{{ option.name }}</label>
                                <select name="options[{{ option.name | escape }}]" class="form-input" style="width:auto; min-width: 180px;" onchange="updateVariant()">
                                    {%- for value in option.values -%}
                                        <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>
                                    {%- endfor -%}
                                </select>
                            </div>
                        {%- endfor -%}
                    </div>
                {%- endif -%}

                <div class="product-qty-row">
                    <span class="qty-label">Quantity</span>
                    <div class="qty-selector">
                        <button type="button" class="qty-btn" onclick="qtyDecrease()">&minus;</button>
                        <input type="number" id="qtyInput" class="qty-input" value="1" min="1" aria-label="Quantity">
                        <button type="button" class="qty-btn" onclick="qtyIncrease()">+</button>
                    </div>
                </div>
            </form>

            <div class="product-trust">
                <div class="trust-item"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg><span>Free shipping over Rs 3,000</span></div>
                <div class="trust-item"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h18v18H3z"/><path d="M3 9h18"/><path d="M9 21V9"/></svg><span>Cash on Delivery</span></div>
                <div class="trust-item"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 4v6h6"/><path d="M3.51 15a9 9 0 102.13-9.36L1 10"/></svg><span>7-day easy returns</span></div>
                <div class="trust-item"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg><span>100% authentic fabric</span></div>
            </div>
        </div>
    </div>

    {%- comment -%} Build a related-products list from the product's first collection (or fallback) {%- endcomment -%}
    {%- assign current_collection = product.collections.first -%}
    {%- if current_collection == blank -%}
        {%- assign current_collection = collections.all -%}
    {%- endif -%}

    {%- comment -%} =============== YOU MAY ALSO LIKE =============== {%- endcomment -%}
    <section class="product-related" aria-labelledby="relatedTitle">
        <h2 class="product-extras-title" id="relatedTitle">You May Also Like</h2>
        <div class="product-related-grid">
            {%- assign related_count = 0 -%}
            {%- for p in current_collection.products -%}
                {%- if p.id != product.id and related_count < 8 -%}
                    {% render 'product-card', product: p %}
                    {%- assign related_count = related_count | plus: 1 -%}
                {%- endif -%}
            {%- endfor -%}
        </div>
    </section>

    {%- comment -%} =============== FREQUENTLY BOUGHT TOGETHER =============== {%- endcomment -%}
    {%- assign fbt_picks = '' -%}
    {%- assign fbt_count = 0 -%}
    {%- for p in current_collection.products -%}
        {%- if p.id != product.id and fbt_count < 2 -%}
            {%- assign fbt_picks = fbt_picks | append: p.id | append: ',' -%}
            {%- assign fbt_count = fbt_count | plus: 1 -%}
        {%- endif -%}
    {%- endfor -%}

    {%- if fbt_count > 0 -%}
    <section class="product-fbt" aria-labelledby="fbtTitle">
        <h2 class="product-extras-title" id="fbtTitle">Frequently Bought Together</h2>
        <div class="fbt-row">
            <div class="fbt-card fbt-card--current">
                <div class="fbt-card-img">
                    {%- if product.featured_image -%}
                        <img src="{{ product.featured_image | image_url: width: 300 }}" alt="{{ product.title | escape }}" loading="lazy">
                    {%- endif -%}
                </div>
                <div class="fbt-card-info">
                    <span class="fbt-card-tag">This item</span>
                    <p class="fbt-card-name">{{ product.title }}</p>
                    <p class="fbt-card-price">{{ product.price | money }}</p>
                </div>
            </div>

            {%- assign fbt_total_cents = product.price -%}
            {%- assign fbt_variant_ids = product.selected_or_first_available_variant.id | append: ',' -%}

            {%- for p in current_collection.products -%}
                {%- if p.id != product.id and forloop.index <= 3 -%}
                    {%- assign fbt_total_cents = fbt_total_cents | plus: p.price -%}
                    {%- assign fbt_variant_ids = fbt_variant_ids | append: p.selected_or_first_available_variant.id | append: ',' -%}
                    <span class="fbt-plus" aria-hidden="true">+</span>
                    <a href="{{ p.url }}" class="fbt-card">
                        <div class="fbt-card-img">
                            {%- if p.featured_image -%}
                                <img src="{{ p.featured_image | image_url: width: 300 }}" alt="{{ p.title | escape }}" loading="lazy">
                            {%- endif -%}
                        </div>
                        <div class="fbt-card-info">
                            <p class="fbt-card-name">{{ p.title }}</p>
                            <p class="fbt-card-price">{{ p.price | money }}</p>
                        </div>
                    </a>
                {%- endif -%}
            {%- endfor -%}
        </div>

        <div class="fbt-summary">
            <div class="fbt-total">
                <span class="fbt-total-label">Bundle total:</span>
                <span class="fbt-total-price">{{ fbt_total_cents | money }}</span>
            </div>
            <button type="button" class="fbt-cta" id="fbtAddBundle" data-variants="{{ fbt_variant_ids | rstrip: ',' }}">
                Add bundle to cart
            </button>
        </div>
    </section>
    {%- endif -%}

    {%- comment -%} =============== CUSTOMER REVIEWS (Judge.me) =============== {%- endcomment -%}
    <section class="product-reviews" aria-labelledby="reviewsTitle">
        <h2 class="product-extras-title" id="reviewsTitle">Customer Reviews</h2>

        {% comment %} Judge.me review widget — auto-injects star rating, review list, write-a-review form {% endcomment %}
        <div id="judgeme_product_reviews"
             class="jdgm-widget jdgm-review-widget"
             data-id="{{ product.id }}"
             data-product-title="{{ product.title | escape }}"
             data-handle="{{ product.handle }}">
            {{ product.metafields.judgeme.widget }}
        </div>
    </section>
</div>

<script>
var PRODUCT_VARIANTS = {{ product.variants | json }};

function syncQty(value) {
    var hidden = document.getElementById('qtyInputHidden');
    if (hidden) hidden.value = value;
}
function qtyDecrease() {
    var input = document.getElementById('qtyInput');
    input.value = Math.max(1, parseInt(input.value || 1) - 1);
    syncQty(input.value);
}
function qtyIncrease() {
    var input = document.getElementById('qtyInput');
    input.value = parseInt(input.value || 1) + 1;
    syncQty(input.value);
}
document.addEventListener('DOMContentLoaded', function(){
    var input = document.getElementById('qtyInput');
    if (input) {
        input.addEventListener('input', function(){
            syncQty(Math.max(1, parseInt(this.value || 1)));
        });
    }
});

function updateVariant() {
    var form = document.getElementById('productForm');
    var selected = [];
    form.querySelectorAll('select[name^="options"]').forEach(function(s){ selected.push(s.value); });
    var variant = PRODUCT_VARIANTS.find(function(v){ return v.options.every(function(opt, i){ return opt === selected[i]; }); });
    if (variant) {
        document.getElementById('variantId').value = variant.id;
        document.getElementById('productPrice').textContent = 'Rs ' + (variant.price / 100).toLocaleString();
        var cmp = document.getElementById('productComparePrice');
        if (cmp && variant.compare_at_price) { cmp.textContent = 'Rs ' + (variant.compare_at_price / 100).toLocaleString(); }
        updateStockUrgency(variant);
    }
}

function updateStockUrgency(variant) {
    var wrap = document.getElementById('stockUrgency');
    if (!wrap) return;
    var threshold = parseInt(wrap.dataset.threshold || '20', 10);
    var qty = (variant.inventory_management && typeof variant.inventory_quantity === 'number') ? variant.inventory_quantity : null;
    if (qty === null || qty <= 0 || qty > threshold) {
        wrap.classList.add('is-hidden');
        return;
    }
    wrap.classList.remove('is-hidden');
    document.getElementById('stockUrgencyCount').textContent = qty;
    var pct = Math.min(100, Math.max(0, (qty / threshold) * 100));
    document.getElementById('stockUrgencyFill').style.width = pct + '%';
}

function handleBuyNow() {
    var form = document.getElementById('productForm');
    var btn = form.querySelector('.btn-cart');
    var formData = new FormData(form);
    fetch(window.routes.cart_add_url, { method: 'POST', body: formData, headers: { 'X-Requested-With': 'XMLHttpRequest', 'Accept': 'application/javascript' } })
        .then(function(r){ return r.json(); })
        .then(function(){ window.location.href = '/checkout'; })
        .catch(function(){ form.submit(); });
}

// ========== FREQUENTLY BOUGHT TOGETHER — Add bundle to cart ==========
(function(){
    var btn = document.getElementById('fbtAddBundle');
    if (!btn) return;
    btn.addEventListener('click', function(){
        var ids = (btn.dataset.variants || '').split(',').filter(Boolean);
        if (!ids.length) return;
        btn.disabled = true;
        btn.textContent = 'Adding…';
        var items = ids.map(function(id){ return { id: parseInt(id, 10), quantity: 1 }; });
        fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({ items: items })
        })
        .then(function(r){ return r.json(); })
        .then(function(){
            btn.textContent = 'Added! View cart →';
            btn.classList.add('fbt-cta--success');
            setTimeout(function(){ window.location.href = '/cart'; }, 700);
        })
        .catch(function(){
            btn.disabled = false;
            btn.textContent = 'Try again';
        });
    });
})();


// ========== PRODUCT GALLERY (swipeable) ==========
(function(){
    var gallery = document.getElementById('productGallery');
    if (!gallery) return;

    var slides   = gallery.querySelectorAll('.product-slide');
    var dots     = document.querySelectorAll('#galleryDots .gallery-dot');
    var thumbs   = document.querySelectorAll('.product-thumb[data-slide]');
    var prevBtn  = document.getElementById('galleryPrev');
    var nextBtn  = document.getElementById('galleryNext');
    var counter  = document.getElementById('galleryCounter');
    var total    = slides.length;
    if (total <= 1) return;

    function currentIndex() {
        return Math.round(gallery.scrollLeft / gallery.clientWidth);
    }

    function goTo(index) {
        index = Math.max(0, Math.min(total - 1, index));
        gallery.scrollTo({ left: index * gallery.clientWidth, behavior: 'smooth' });
    }

    function updateActive() {
        var i = currentIndex();
        dots.forEach(function(d, di){ d.classList.toggle('is-active', di === i); });
        thumbs.forEach(function(t, ti){ t.classList.toggle('active', ti === i); });
        if (counter) counter.textContent = (i + 1) + ' / ' + total;

        // Scroll active thumb into view
        var activeThumb = thumbs[i];
        if (activeThumb && activeThumb.scrollIntoView) {
            activeThumb.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'nearest' });
        }
    }

    var scrollTimer;
    gallery.addEventListener('scroll', function(){
        clearTimeout(scrollTimer);
        scrollTimer = setTimeout(updateActive, 80);
    }, { passive: true });

    dots.forEach(function(dot){
        dot.addEventListener('click', function(){ goTo(parseInt(this.dataset.slide, 10)); });
    });

    thumbs.forEach(function(thumb){
        thumb.addEventListener('click', function(){ goTo(parseInt(this.dataset.slide, 10)); });
    });

    if (prevBtn) prevBtn.addEventListener('click', function(){ goTo(currentIndex() - 1); });
    if (nextBtn) nextBtn.addEventListener('click', function(){ goTo(currentIndex() + 1); });

    // Keyboard arrows when gallery is focused
    gallery.setAttribute('tabindex', '0');
    gallery.addEventListener('keydown', function(e){
        if (e.key === 'ArrowLeft')  { e.preventDefault(); goTo(currentIndex() - 1); }
        if (e.key === 'ArrowRight') { e.preventDefault(); goTo(currentIndex() + 1); }
    });

    updateActive();
})();
</script>
