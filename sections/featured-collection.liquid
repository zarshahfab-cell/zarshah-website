<div id="shopContent" style="display: none;">

<section class="collection-section">
    <div class="collection-layout">
        <!-- Left: Intro -->
        <div class="collection-intro">
            <h2>{{ section.settings.heading | default: 'Premium Collection' }}</h2>
            <p>{{ section.settings.description | default: '<strong>Year End Sale</strong> — Embrace the supreme feel of our most comfortable premium fabric, crafted for the modern Pakistani man.' }}</p>
            <a href="{{ section.settings.cta_link | default: '/collections/all' }}" class="collection-cta">{{ section.settings.cta_label | default: 'Shop Collection' }}</a>
        </div>

        <!-- Right: Grid -->
        <div class="collection-grid">
            {%- assign collection_handle = section.settings.collection | default: 'featured' -%}
            {%- assign collection_obj = collections[collection_handle] -%}

            {%- if collection_obj.products.size > 0 -%}
                {%- for product in collection_obj.products limit: section.settings.product_limit -%}
                    {% render 'product-card', product: product %}
                {%- endfor -%}
            {%- else -%}
                {%- for product in collections.all.products limit: section.settings.product_limit -%}
                    {% render 'product-card', product: product %}
                {%- endfor -%}
            {%- endif -%}
        </div>
    </div>
</section>

</div>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Premium Collection" },
    { "type": "richtext", "id": "description", "label": "Description", "default": "<p><strong>Year End Sale</strong> — Embrace the supreme feel of our most comfortable premium fabric, crafted for the modern Pakistani man.</p>" },
    { "type": "collection", "id": "collection", "label": "Collection to show" },
    { "type": "text", "id": "cta_label", "label": "CTA Label", "default": "Shop Collection" },
    { "type": "url", "id": "cta_link", "label": "CTA Link" },
    { "type": "range", "id": "product_limit", "label": "Products to show", "min": 3, "max": 12, "step": 1, "default": 6 }
  ],
  "presets": [
    { "name": "Featured Collection" }
  ]
}
{% endschema %}
