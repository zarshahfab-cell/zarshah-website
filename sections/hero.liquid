<section class="hero">
    <div class="hero-bg">
        <img src="{{ 'bg-texture.png' | asset_url }}" alt="Fabric Texture">
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-content" style="flex-direction: column; align-items: center; text-align: center; gap: 0;">
        <h1 class="hero-title" data-text="{{ section.settings.tagline_urdu | default: 'ہر تار ایک کہانی ہے' }}" style="font-family: 'Noto Nastaliq Urdu', 'Amiri', serif; direction: rtl; letter-spacing: 0; font-size: clamp(2.5rem, 10vw, 8rem);">{{ section.settings.tagline_urdu | default: 'ہر تار ایک کہانی ہے' }}</h1>
        <div class="hero-tagline-wrap" style="display: inline-flex; flex-direction: column; align-items: stretch; margin-bottom: 32px;">
            <div style="height: 2px; background: #C9A84C; margin-bottom: 12px;"></div>
            <p class="hero-english-tagline" style="font-size: clamp(1.2rem, 2.4vw, 1.76rem); color: #A0A8B0; font-style: italic; letter-spacing: 6px; margin: 0;">&ldquo;{{ section.settings.tagline_en | default: 'Every thread holds a story' }}&rdquo;</p>
            <div style="height: 2px; background: #C9A84C; margin-top: 12px;"></div>
        </div>
        <a href="{{ section.settings.cta_link | default: '/collections/all' }}" class="btn-primary">{{ section.settings.cta_label | default: 'SHOP NOW' }} &rarr;</a>
    </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "tagline_urdu", "label": "Urdu Tagline", "default": "ہر تار ایک کہانی ہے" },
    { "type": "text", "id": "tagline_en", "label": "English Tagline", "default": "Every thread holds a story" },
    { "type": "text", "id": "cta_label", "label": "Button Label", "default": "SHOP NOW" },
    { "type": "url", "id": "cta_link", "label": "Button Link", "default": "/collections/all" }
  ]
}
{% endschema %}
