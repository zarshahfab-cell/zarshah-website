<footer class="site-footer">
    <div class="footer-inner">
        <div class="footer-top">
            <!-- Brand Column -->
            <div class="footer-brand-col">
                <div class="footer-logo-wrap">
                    <img src="{{ 'top-web-image.png' | asset_url }}" alt="Zarshah" class="footer-logo">
                    <img src="{{ 'brand-name.png' | asset_url }}" alt="ZARSHAH — Premium Men's Wear" class="footer-brand-img">
                </div>
                <p class="footer-brand-desc">Premium unstitched fabrics for the modern Pakistani man. Crafted with heritage, designed for today.</p>
                <div class="footer-socials">
                    <a href="{{ section.settings.instagram_url | default: 'https://www.instagram.com/zarshahofficial' }}" target="_blank" class="footer-social-link" aria-label="Instagram">
                        <svg viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                    </a>
                    <a href="{{ section.settings.facebook_url | default: 'https://www.facebook.com/share/1B3J5mLPyw/' }}" target="_blank" class="footer-social-link" aria-label="Facebook">
                        <svg viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                    </a>
                    <a href="https://wa.me/{{ section.settings.whatsapp_number | default: '923113638999' }}" target="_blank" class="footer-social-link" aria-label="WhatsApp">
                        <svg viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347M12 2a10 10 0 00-8.4 15.4L2 22l4.7-1.5A10 10 0 1012 2z"/></svg>
                    </a>
                </div>
            </div>

            <!-- Contact Column -->
            <div class="footer-col">
                <h4 class="footer-col-title">Stay Connected</h4>
                <div class="footer-contact-item">
                    <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    <span>{{ section.settings.address | default: 'Lahore, Pakistan' }}</span>
                </div>
                <div class="footer-contact-item" style="margin-top: 12px;">
                    <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    <a href="mailto:{{ section.settings.email | default: 'hello@zarshah.pk' }}">{{ section.settings.email | default: 'hello@zarshah.pk' }}</a>
                </div>
                <div class="footer-contact-item" style="margin-top: 12px;">
                    <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
                    <a href="tel:{{ section.settings.phone | default: '+923113638999' }}">{{ section.settings.phone | default: '+92 311 3638999' }}</a>
                </div>
                <h4 class="footer-col-title" style="margin-top: 24px; margin-bottom: 12px;">Newsletter</h4>
                <p style="color: #A0A8B0; font-size: 0.8rem; line-height: 1.5;">Get 10% off your first order.</p>
                {% form 'customer' %}
                    <input type="hidden" name="contact[tags]" value="newsletter">
                    <div class="footer-newsletter">
                        <input type="email" name="contact[email]" placeholder="Your email" required>
                        <button type="submit">JOIN</button>
                    </div>
                {% endform %}
            </div>
        </div>

        <!-- Horizontal Legal Links -->
        <nav class="footer-legal-strip" aria-label="Legal">
            <a href="/policies/privacy-policy">Privacy Policy</a>
            <span class="footer-legal-sep" aria-hidden="true">&middot;</span>
            <a href="/policies/terms-of-service">Terms of Service</a>
            <span class="footer-legal-sep" aria-hidden="true">&middot;</span>
            <a href="/policies/refund-policy">Refund Policy</a>
            <span class="footer-legal-sep" aria-hidden="true">&middot;</span>
            <a href="/pages/cookie-policy">Cookie Policy</a>
        </nav>

        <!-- Bottom Strip -->
        <div class="footer-bottom">
            <div class="footer-copyright">
                &copy; {{ 'now' | date: '%Y' }} <span class="gold">{{ shop.name | upcase }}</span>. All rights reserved.
            </div>
            <div class="footer-payments">
                <div class="footer-payment-icons">
                    <span class="footer-payment-badge">VISA</span>
                    <span class="footer-payment-badge">MC</span>
                    <span class="footer-payment-badge">JazzCash</span>
                    <span class="footer-payment-badge">EasyPaisa</span>
                    <span class="footer-payment-badge">COD</span>
                </div>
            </div>
        </div>
    </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "address", "label": "Address", "default": "Lahore, Pakistan" },
    { "type": "text", "id": "email", "label": "Email", "default": "hello@zarshah.pk" },
    { "type": "text", "id": "phone", "label": "Phone", "default": "+92 311 3638999" },
    { "type": "text", "id": "whatsapp_number", "label": "WhatsApp Number (no +)", "default": "923113638999" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "url", "id": "facebook_url", "label": "Facebook URL" }
  ]
}
{% endschema %}
